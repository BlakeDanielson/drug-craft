# Copy to .env (or just export these) to enable the optional AI backend.
# The game is fully playable WITHOUT any of this — it falls back to the
# offline deterministic engine in engine.js.

# Required for AI mode:
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides:
# DRUGCRAFT_MODEL=claude-haiku-4-5   # default; try claude-opus-4-8 for richer combos
# PORT=8787
